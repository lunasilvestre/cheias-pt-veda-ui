{
  "buildCommand": "yarn --ignore-engines && yarn --ignore-engines build",
  "outputDirectory": "dist",
  "installCommand": "yarn --ignore-engines && cd .veda/ui && yarn --ignore-engines && cd ../..",
  "redirects": [
    {
      "source": "/",
      "destination": "/stories/winter-2025-26-floods",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
